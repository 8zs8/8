// Installer resource script
// Uses the same icon file as the main program: app.ico

1 ICON "app.ico"

1 VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEOS          VOS__WINDOWS32
FILETYPE        VFT_APP
{
    BLOCK "StringFileInfo"
    {
        BLOCK "080404E4"
        {
            VALUE "CompanyName",     "8zs8\0"
            VALUE "FileDescription", "Quick Web Launcher - Installer\0"
            VALUE "FileVersion",     "1.0.0.0\0"
            VALUE "InternalName",    "Installer\0"
            VALUE "LegalCopyright",  "Copyright (C) 2026\0"
            VALUE "OriginalFilename","installer.exe\0"
            VALUE "ProductName",     "QuickWebLauncher\0"
            VALUE "ProductVersion",  "1.0.0.0\0"
        }
    }
    BLOCK "VarFileInfo"
    {
        VALUE "Translation", 0x804, 0x4E4
    }
}

// Application manifest (Common Controls v6 + DPI awareness)
1 24 "manifest.xml"

// =====================================================================
//  Main program (app.exe) embedded as binary RCDATA resource.
//  At install time it will be extracted to the target directory.
//  Resource ID: 1001
// =====================================================================
1001 RCDATA "app.exe"

// Main program icon (also extracted to target directory)
// Resource ID: 1002
1002 RCDATA "app.ico"
