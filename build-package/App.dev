[Project]
FileName=App.dev
UnitCount=2
Type=1
Ver=1
Name=抽人软件
IsCpp=1

CompilerOptions=-O2
CppOptions=-O2

; ====================================================================
;  IMPORTANT - how library linking works in Dev-C++
;  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
;  -lxxx library flags MUST be on the LINKER command line, not
;  the compile command line. Some Dev-C++ versions automatically
;  copy the "Libs" field to BOTH compile and link commands, which
;  causes the "linker input file unused because linking not done"
;  warning and breaks linking.
;
;  Solution: Leave Libs EMPTY here and put ALL linker flags
;  (-mwindows and -lxxx) in LinkerOptions ONLY.
;
;  The source file (app.cpp) also has #pragma comment(lib, ...)
;  declarations which provide a second way to force the linker
;  to include the required libraries.
; ====================================================================

LinkerOptions=-mwindows -static-libgcc -static-libstdc++ -luser32 -lgdi32 -lmsimg32 -lshell32 -lcomctl32
Libs=

MakeFileName=
Options=0
Include1=
Include2=
Include3=
Include4=
Include5=

[Unit1]
FileName=app.cpp
Folder=
Compile=1
Link=1
CompileCpp=1

[Unit2]
FileName=app.rc
Folder=
Compile=1
Link=1
CompileCpp=0

